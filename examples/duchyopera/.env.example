# Duchy Opera generated app environment
# Fill values in deployment secrets; do not commit real secret values.

NODE_ENV=development
DB_PATH=./data/duchy-opera.db
PORT=3085
MCP_PORT=3086
AUTH_ENABLED=true
CORS_ORIGINS=https://duchyopera.example

# Provide one registry mode in production.
REGISTRY_PRIVATE_KEY=
REGISTRY_PUBLIC_KEY=
ALLOW_EPHEMERAL_REGISTRY_KEYS=false

# Declared email and payment effects.
EMAIL_WEBHOOK_URL=
PAYMENT_PROVIDER=stripe
PAYMENT_API_KEY=

MAX_REQUEST_BODY_BYTES=1048576
MAX_PAGE_LIMIT=1000
ROUTE_TIMEOUT_MS=30000
EFFECT_MAX_ATTEMPTS=3
EFFECT_RETRY_DELAY_MS=1000
